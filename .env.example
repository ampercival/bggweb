# Copy to .env and adjust. The real .env is git-ignored.
# All variables are optional unless noted; defaults are shown.

# --- Core Django ---
# Required in production (DEBUG=False). Dev/tests fall back to an insecure key.
DJANGO_SECRET_KEY=
# Set True for local development (nicer error pages, permissive ALLOWED_HOSTS).
DJANGO_DEBUG=False
# Comma-separated. Required when DEBUG=False.
DJANGO_ALLOWED_HOSTS=
# Comma-separated, e.g. https://example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
# One of DEBUG, INFO, WARNING, ERROR (default INFO).
DJANGO_LOG_LEVEL=INFO

# --- Database ---
# Any dj-database-url URL. Defaults to local SQLite (db.sqlite3) when unset.
# Example: postgres://user:pass@host:5432/dbname
DATABASE_URL=

# --- Security toggles (only applied when DEBUG=False; sensible defaults) ---
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# --- BoardGameGeek client ---
# Optional bearer token for the BGG API.
BGG_API_TOKEN=
# Throttle (seconds) between BGG requests. Defaults: 1.5 and max(1.5, 2.5).
BGG_THROTTLE_SEC=1.5
BGG_DETAILS_THROTTLE_SEC=2.5

# --- Rally the Troops scraper ---
# Throttle (seconds) between rally-the-troops.com requests (default 1.0).
RTT_THROTTLE_SEC=1.0
